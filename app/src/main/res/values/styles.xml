    <style name="AppTheme" parent="Theme.Material3Expressive.DynamicColors.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">?attr/isLightTheme</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">?attr/isLightTheme</item>

        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/primary_container_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_color</item>

        <item name="colorSecondary">@color/accent_color</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_container_light</item>
        <item name="colorOnSecondaryContainer">@color/accent_color</item>

        <item name="colorTertiary">@color/accent_color</item>
        <item name="colorOnTertiary">@android:color/white</item>
        <item name="colorTertiaryContainer">@color/accent_color</item>
        <item name="colorOnTertiaryContainer">@android:color/white</item>

        <item name="colorError">#D93F1E</item>
        <item name="colorOnError">@android:color/white</item>
        <item name="colorErrorContainer">#FFDAD6</item>
        <item name="colorOnErrorContainer">#410002</item>

        <item name="colorSurface">@color/surface_color_light</item>
        <item name="colorOnSurface">@color/text_primary_color_light</item>
        <item name="colorSurfaceVariant">#E7E0EC</item>
        <item name="colorOnSurfaceVariant">#49454F</item>
        <item name="colorSurfaceContainer">@color/surface_container_light</item>
        <item name="colorSurfaceContainerLow">#F0F0F0</item>

        <item name="colorOutline">#79747E</item>
        <item name="colorOutlineVariant">#CAC4D0</item>

        <item name="android:windowBackground">@color/surface_color_light</item>

        <item name="text_primary_color">@color/text_primary_color_light</item>
        <item name="text_secondary_color">#4E4E4E</item>
        <item name="donate_card_background">#F0F0F0</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <item name="bottom_bar_background">@color/bottom_nav_background_light</item>

        <item name="toolbar_background">@color/surface_color_light</item>
        <item name="search_toolbar_background">@color/surface_color_light</item>

        <item name="divider_color">@color/divider_light</item>

        <item name="compose_background">@drawable/compose_background_light</item>
