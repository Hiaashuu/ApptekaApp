    <style name="AppPreferenceThemeOverlay" parent="@style/PreferenceThemeOverlay">
        <item name="switchPreferenceCompatStyle">@style/AppSwitchPreference</item>
    </style>

    <style name="AppSwitchPreference" parent="@style/Preference.SwitchPreferenceCompat.Material">
        <item name="widgetLayout">@layout/preference_material_switch</item>
    </style>

    <style name="AppThemeSemitransparent" parent="Theme.Material3Expressive.Dark.NoActionBar">
        <item name="android:statusBarColor">#CC000000</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowBackground">@android:color/black</item>

        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/primary_container_dark</item>
        <item name="colorOnPrimaryContainer">@android:color/white</item>

        <item name="colorSecondary">@color/accent_color</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_container_dark</item>
        <item name="colorOnSecondaryContainer">@color/accent_color</item>

        <item name="colorSurface">@android:color/black</item>
        <item name="colorOnSurface">@color/text_primary_color_dark</item>
        <item name="colorSurfaceVariant">#49454F</item>
        <item name="colorOnSurfaceVariant">#CAC4D0</item>
        <item name="colorOutline">#938F99</item>
        <item name="colorOutlineVariant">#49454F</item>

        <item name="text_primary_color">@color/text_primary_color_dark</item>
        <item name="text_secondary_color">#B1B1B1</item>
        <item name="toolbar_background">@android:color/black</item>
        <item name="menu_icons_tint">@color/icons_grey_dark</item>
        <item name="divider_color">@color/divider_dark</item>
        <item name="semitransparent_color">@color/color_semitransparent_black</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="appBarLayoutStyle">@style/AppBarLayoutStyle</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar" />

    <style name="AppBarLayoutStyle" parent="Widget.Material3.AppBarLayout">
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3" />

    <style name="Chat.Message" parent="android:Widget.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">2dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_gravity">left|center_vertical</item>
        <item name="android:singleLine">false</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="Chat.Message.Outgoing" parent="Chat.Message">
        <item name="android:textColor">?attr/colorOnPrimaryContainer</item>
        <item name="android:textColorLink">?attr/colorOnPrimaryContainer</item>
    </style>

    <style name="RatingDetailElementSmall" parent="@style/Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">8dp</item>
        <item name="android:max">101</item>
        <item name="android:progressDrawable">@drawable/rating_detail_element</item>
    </style>

    <style name="MaterialButtonPrimary" parent="@style/Widget.Material3Expressive.Button">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonSecondary" parent="@style/Widget.Material3Expressive.Button.TextButton">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonSecondaryOutline" parent="@style/Widget.Material3Expressive.Button.OutlinedButton">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonElevated" parent="@style/Widget.Material3Expressive.Button.ElevatedButton">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonIcon" parent="@style/Widget.Material3Expressive.Button.IconButton">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonIconFilled" parent="@style/Widget.Material3Expressive.Button.IconButton.Filled">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonIconOutlined" parent="@style/Widget.Material3Expressive.Button.IconButton.Outlined">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonIconStandard" parent="@style/Widget.Material3Expressive.Button.IconButton.Standard">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialButtonIconTonal" parent="@style/Widget.Material3Expressive.Button.IconButton.Tonal">
        <item name="textAllCaps">false</item>
    </style>

    <style name="MaterialCardViewExpressive" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">1dp</item>
    </style>

    <style name="MaterialCardViewExpressiveLarge" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">1dp</item>
    </style>

    <style name="MaterialTextInputExpressive" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyLarge</item>
        <item name="hintTextAppearance">@style/TextAppearance.Material3.BodyLarge</item>
    </style>

    <style name="MaterialFABExpressive" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="elevation">3dp</item>
        <item name="pressedTranslationZ">6dp</item>
        <item name="fabSize">normal</item>
    </style>

    <style name="BottomSheetDialogLight" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetDialogDark" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="behavior_hideable">true</item>
        <item name="behavior_skipCollapsed">true</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/colorPrimaryContainer</item>
    </style>

    <style name="AppBottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/BottomNavActiveIndicator</item>
    </style>

    <style name="DefaultBottomNavStyle" parent="AppBottomNavigationView" />

    <style name="DefaultThemeOverlay">
        <item name="bottomNavigationStyle">@style/AppBottomNavigationView</item>
    </style>

    <style name="ShapeAppearance.Appteka.Circle" parent="">
        <item name="cornerSize">50%</item>
        <item name="cornerFamily">rounded</item>
    </style>

