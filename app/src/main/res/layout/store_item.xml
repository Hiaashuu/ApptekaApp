<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/app_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:rippleColor="?attr/colorPrimary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/icon_back"
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="14dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp">

                <ImageView
                    android:id="@+id/app_icon"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:contentDescription="@string/app_icon"
                    android:scaleType="centerCrop"
                    tools:src="@mipmap/ic_launcher" />

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:orientation="vertical">

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/badge_new"
                        android:layout_width="wrap_content"
                        android:layout_height="18dp"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/ratings"
                        android:paddingEnd="3dp"
                        android:src="@drawable/ic_new_box"
                        android:visibility="visible"
                        app:tint="@color/badge_color" />

                    <TextView
                        android:id="@+id/app_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:includeFontPadding="false"
                        android:singleLine="true"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:scrollHorizontally="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="AppSend Long Name That Scrolls" />

                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp">

                    <TextView
                        android:id="@+id/app_version"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:includeFontPadding="false"
                        android:singleLine="true"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:scrollHorizontally="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        tools:text="3.4 (5420)" />

                    
                    <LinearLayout
                        android:id="@+id/app_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/round_name_back"
                        android:backgroundTint="?attr/colorTertiaryContainer"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:id="@+id/app_badge_icon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:importantForAccessibility="no"
                            android:layout_marginEnd="5dp"
                            android:src="@drawable/ic_pill_ok"
                            app:tint="?attr/colorOnTertiaryContainer" />

                        <TextView
                            android:id="@+id/app_badge_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:textColor="?attr/colorOnTertiaryContainer"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Installed" />

                    </LinearLayout>

                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/app_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:singleLine="true"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginEnd="6dp"
                        tools:text="3.1 MB" />

                    <TextView
                        android:id="@+id/app_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:background="@drawable/round_name_back"
                        android:backgroundTint="?attr/colorSecondaryContainer"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="1dp"
                        android:singleLine="true"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:id="@+id/app_category_icon"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/rating_icon"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="2dp"
                        android:contentDescription="@string/ratings"
                        android:src="@drawable/ic_star_smooth"
                        android:visibility="visible"
                        app:tint="@color/badge_color" />

                    <TextView
                        android:id="@+id/app_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        android:visibility="visible"
                        tools:text="4.8" />

                    <ImageView
                        android:id="@+id/downloads_icon"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="2dp"
                        android:contentDescription="@string/downloads"
                        android:src="@drawable/ic_download_smooth"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/app_downloads"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:paddingStart="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        tools:text="15" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:id="@+id/open_source"
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@string/open_source"
                        android:src="@drawable/ic_open_source"
                        android:visibility="gone"
                        app:tint="?attr/colorOnSurfaceVariant"
                        tools:visibility="visible" />

                    <ImageView
                        android:id="@+id/abi_incompatible"
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="@string/abi_incompatible"
                        android:src="@drawable/ic_alert_circle"
                        android:visibility="gone"
                        app:tint="@color/abi_incompatible_color"
                        tools:visibility="visible" />

                </LinearLayout>

            </LinearLayout>

            <ImageView
                android:id="@+id/app_menu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="?selectableItemBackgroundBorderless"
                android:importantForAccessibility="no"
                android:padding="10dp"
                android:src="@drawable/ic_dots_vertical"
                android:visibility="gone"
                app:tint="?attr/colorOnSurfaceVariant"
                tools:visibility="visible" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/item_progress"
        style="@style/Widget.Material3Expressive.CircularProgressIndicator.Wavy"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginVertical="16dp"
        android:indeterminate="true"
        android:visibility="gone"
        tools:visibility="gone" />

    <LinearLayout
        android:id="@+id/error_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="12dp"
            android:text="@string/store_loading_error"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_retry"
            style="@style/MaterialButtonSecondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/retry" />

    </LinearLayout>

</LinearLayout>